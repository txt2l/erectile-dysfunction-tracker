{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build"
  },
  "deploy": {
    "startCommand": "node dist/server.js",
    "healthCheckPath": "/api/health",
    "numReplicas": 1,
    "sleepApplication": false
  }
}
